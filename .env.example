# Application
APP_NAME=OSTO
DATABASE_PATH=/app/data/app.db

# Security thresholds (not hardcoded — override as needed)
MAX_FAILED_LOGIN_ATTEMPTS=5
MAX_TOTP_ATTEMPTS=3
SESSION_TIMEOUT_MINUTES=30
SESSION_WARNING_MINUTES=5
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60

# When true, reset tokens are printed to the console instead of sent via SMTP
DEV_MODE=true

# SMTP (required when DEV_MODE=false)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@osto.local
